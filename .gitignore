/shell3
/bin/
ai-do-not-read.*
# ./.shell3/ is runtime scratch + per-project identity — never committed.
# A "*" in .shell3/.gitignore ignores the whole folder, but list it here too
# so it stays ignored even if that file is missing.
/.shell3/

# AI dev-process artifacts (kept local, not shipped publicly)
CLAUDE.md
docs/superpowers/
docs/dev/superpowers/

# Build / test artifacts
*.out
*.prof
*.pprof
*.coverprofile
coverage.txt

# test coverage profile
cover.out

# stress-test scratch artifacts
/.stress_scratch
/tmp/
