-- shell3.lua — Telegram host config written by `shell3 boot --telegram`.
-- Secrets (TELEGRAM_BOT_TOKEN and the model api key) live in .env beside this file.
-- Edit freely, then apply changes live with the `reload` tool (see the self-evolve skill).
-- Run it with:  shell3 telegram

local tools   = require("lib.tools")   -- { web_fetch, brave_search }
local browser = require("lib.skills.browser")
local history = require("lib.skills.history")

local self_evolve = shell3.skill({
  name = "self-evolve",
  description = "How to safely change your own shell3.lua config and apply it live with the reload + status tools. A failed reload keeps the old config, so self-editing is always safe.",
  path = "lib/skills/self-evolve.md",
})

local scheduling_jobs = shell3.skill({
  name = "scheduling-jobs",
  description = "How to add, arm, and test recurring scheduled jobs (the cron list inside shell3.telegram). A cron job dispatches a SUBAGENT on a schedule; arm it with reload and fire it on demand with /run.",
  path = "lib/skills/scheduling-jobs.md",
})

-- ---------------------------------------------------------------------------
-- Model
-- ---------------------------------------------------------------------------
shell3.model("{{.Name | luaesc}}", {
  base_url       = "{{.BaseURL | luaesc}}",
  api_key        = shell3.env.secret("{{.EnvKey}}"),  -- {{.EnvKey}} in .env
  model          = "{{.Model | luaesc}}",
  context_window = {{.ContextWindow}},
  -- compact_at: prompt-token threshold for host-enforced auto-compaction (0 = off).
  compact_at     = {{.CompactAt}},
  -- extra: provider-specific fields injected verbatim as top-level JSON on each
  -- request. Leave empty unless your provider needs a non-standard knob — strict
  -- endpoints reject unknown fields. e.g. MiniMax routes thinking to reasoning_content:
  -- extra       = { reasoning_split = true },
{{if .Proxy}}  run_proxy      = "{{.Proxy | luaesc}}",
{{else}}  -- run_proxy   = "npx @some/codex-proxy --port 8787",
{{end}}})

-- ---------------------------------------------------------------------------
-- Command gate — shell3.on_tool_call (YOUR ONLY POLICY GATE)
-- ---------------------------------------------------------------------------
-- UNSAFE BY DEFAULT: tools run with no restrictions. on_tool_call is the one place
-- a model-issued action can be inspected, rewritten, routed, or blocked. It fires
-- before EVERY tool with the real t.name (bash, bash_bg, shell_interactive, read,
-- list_files, edit_file, custom). t.command is the bash text for the three bash
-- tools and NIL otherwise — so guard on t.name before matching t.command. (The
-- Telegram host strips shell_interactive; in the TUI it is gated like the rest.)
-- Handlers are chainable (declaration order) and receive t = { name, command, args }.
-- Return one of:
--   * nil                         → pass to the next handler / run
--   * { command = "..." }         → rewrite the bash text, continue (bash tools only)
--   * { argv = {...} }            → exec this argv directly (runner swap; bash/bash_bg
--                                   only — fails closed for shell_interactive)
--   * { block = true, reason="" } → block (reason shown to the model)
--   * { ask = "prompt", reason="" } → ask a human (TUI y/N or Telegram buttons);
--                                   allowed → run, declined/headless → block(reason)
-- Write denylists with shell3.regex (Go RE2; compiled at load). Use (?s) so .*
-- spans multi-line commands. A handler that errors FAILS CLOSED (blocks).
-- Example (uncomment to enable a guard):
