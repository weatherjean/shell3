--     for _, p in ipairs(ASK)  do if p:match(t.command) then return { ask = "Run?\n" .. t.command, reason = "denied" } end end
--   end
--   -- non-bash tools fire too — gate them by t.name + t.args, e.g.:
--   -- if t.name == "read" and ENV:match(t.args) then return { block = true, reason = "no .env" } end
