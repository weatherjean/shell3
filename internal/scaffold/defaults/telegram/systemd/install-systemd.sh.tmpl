#!/usr/bin/env bash
# Install the shell3 Telegram bot as a systemd system service.
# Generated by `shell3 boot --telegram`. Safe to re-run.
set -euo pipefail

SERVICE_NAME="{{.ServiceName}}"
DEFAULT_BIN="{{.DefaultBin}}"
SRC_CONFIG_DIR="{{.ConfigDir}}"   # e.g. /root/.shell3/telegram
SRC_HOME="{{.Home}}"              # e.g. /root

MODE="user"          # user | root
RUN_USER="shell3"

usage() {
  cat <<EOF
Usage: $0 [--root] [--user NAME]

  (default)    Create a dedicated unprivileged 'shell3' user, relocate the
               config into its home, and run the service as that user.
  --root       Run the service as root; config stays in $SRC_CONFIG_DIR.
  --user NAME  Use NAME as the dedicated service user instead of 'shell3'.
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --root) MODE="root"; shift ;;
    --user) RUN_USER="${2:?--user needs a name}"; MODE="user"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "unknown arg: $1" >&2; usage; exit 2 ;;
  esac
done

if [ "$(id -u)" -ne 0 ]; then
  echo "error: must run as root (try: sudo bash $0 ...)" >&2
  exit 1
fi

# Resolve the shell3 binary: prefer PATH, fall back to the baked-in path.
BIN="$(command -v shell3 || true)"
[ -z "$BIN" ] && BIN="$DEFAULT_BIN"
if [ ! -x "$BIN" ]; then
  echo "error: shell3 binary not found (looked for 'shell3' on PATH and $DEFAULT_BIN)" >&2
  exit 1
fi

if [ "$MODE" = "root" ]; then
  RUN_USER="root"
  RUN_HOME="$SRC_HOME"
  CONFIG_DIR="$SRC_CONFIG_DIR"
else
  RUN_HOME="/home/$RUN_USER"
  CONFIG_DIR="$RUN_HOME/.shell3/telegram"
  if ! id -u "$RUN_USER" >/dev/null 2>&1; then
    useradd --system --create-home --home-dir "$RUN_HOME" --shell /usr/sbin/nologin "$RUN_USER"
    echo "created service user: $RUN_USER ($RUN_HOME)"
  fi
  [ -d "$RUN_HOME" ] || { echo "error: $RUN_HOME missing after useradd" >&2; exit 1; }
  if [ ! -f "$CONFIG_DIR/shell3.lua" ]; then
    mkdir -p "$(dirname "$CONFIG_DIR")"
    cp -a "$SRC_CONFIG_DIR" "$CONFIG_DIR"
    # Rewrite baked absolute paths (e.g. workdir) into the new home.
    sed -i "s#${SRC_HOME}/.shell3#${RUN_HOME}/.shell3#g" "$CONFIG_DIR/shell3.lua"
    echo "relocated config: $SRC_CONFIG_DIR -> $CONFIG_DIR"
  else
    echo "config already at $CONFIG_DIR (left untouched)"
  fi
  chown -R "$RUN_USER":"$RUN_USER" "$RUN_HOME/.shell3"
fi

UNIT_PATH="/etc/systemd/system/${SERVICE_NAME}.service"
USER_LINE=""
GROUP_LINE=""
if [ "$MODE" != "root" ]; then
  USER_LINE="User=$RUN_USER"
  GROUP_LINE="Group=$RUN_USER"
fi

cat > "$UNIT_PATH" <<EOF
[Unit]
Description=shell3 Telegram bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
$USER_LINE
$GROUP_LINE
Environment=HOME=$RUN_HOME
WorkingDirectory=$CONFIG_DIR
ExecStart=$BIN telegram --config $CONFIG_DIR/shell3.lua
Restart=always
RestartSec=3
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
echo "wrote unit: $UNIT_PATH"

systemctl daemon-reload
systemctl enable --now "$SERVICE_NAME"

echo
echo "shell3-telegram installed and running as: $RUN_USER"
echo "  status:  systemctl status $SERVICE_NAME"
echo "  logs:    journalctl -u $SERVICE_NAME -f"
echo "  restart: systemctl restart $SERVICE_NAME"
