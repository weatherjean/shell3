# shell3 secrets — copy this file to ".env" next to your shell3.lua and fill in
# the values below. shell3 reads keys from .env via shell3.env.secret("KEY").
# Never commit your real .env (the global .gitignore already excludes secrets).

# API key for the OpenCode-compatible provider used by shell3.model(...).
OPENCODE_KEY=

# API key for the Brave Search API, used by the web search tool.
BRAVE_API_KEY=

# Password for the `shell3 web` portal login. Leave empty to disable auth
# (only safe when binding 127.0.0.1). Required to bind a non-loopback host.
WEB_PASSWORD=
