-- shell3.lua — base config written by `shell3 boot`. Edit freely.
-- Secrets live in .env beside this file (never commit it).
-- Add tools, skills, or agents by editing — see the cookbook in
-- the shell3 repo under docs/cookbook/.

local tools  = require("lib.tools")            -- { web_fetch, brave_search }
local brainstorming = require("lib.skills.brainstorming")
local history = require("lib.skills.history")

-- Tip: a skill's body lives in a file the agent reads with `cat`; declare the
-- skill with its path (resolved relative to this config's directory at load):
--   shell3.skill({ name="history", description="...", path="lib/skills/history.md" })
-- An agent's prompt can likewise come from a file via prompt_cmd:
--   shell3.agent({ name="build", model="...", prompt_cmd="cat lib/prompts/build.md", ... })
local self_evolve = shell3.skill({
  name = "self-evolve",
  description = "How to safely change your own shell3.lua config and apply it live with the reload tool. A failed reload keeps the old config, so self-editing is always safe.",
  path = "lib/skills/self-evolve.md",
})

-- ---------------------------------------------------------------------------
-- Model
-- ---------------------------------------------------------------------------
shell3.model("{{.Name | luaesc}}", {
  base_url       = "{{.BaseURL | luaesc}}",
  api_key        = shell3.env.secret("{{.EnvKey}}"),  -- {{.EnvKey}} in .env
  model          = "{{.Model | luaesc}}",
  -- context_window: your model's token budget. Set it to the real value for
  -- this model — the wrong number throws off context-usage reminders and compaction.
  context_window = {{.ContextWindow}},
  -- compact_at: absolute prompt-token threshold for host-enforced auto-compaction.
  -- When a turn's prompt reaches it, shell3 summarizes the conversation so far and
  -- continues against the summary — no model-driven prune/compact tools. 0/unset = off.
  compact_at     = {{.CompactAt}},
  -- reasoning   = "medium",   -- uncomment if your model supports reasoning effort
  -- extra: provider-specific fields injected verbatim as top-level JSON on each
  -- request. Leave empty unless your provider needs a non-standard knob — strict
  -- endpoints reject unknown fields. e.g. MiniMax routes thinking to reasoning_content:
  -- extra       = { reasoning_split = true },
  -- run_proxy: shell command auto-started (detached, fire-and-forget) the first
  -- time an agent uses this model. Use it to bring up a local proxy in front of
  -- base_url — e.g. a Codex subscription fronted by `npx ...`.
  -- Output goes to ./.shell3/proxy-{{.Name}}.log.
{{if .Proxy}}  run_proxy      = "{{.Proxy | luaesc}}",
{{else}}  -- run_proxy   = "npx @some/codex-proxy --port 8787",
{{end}}})

-- ---------------------------------------------------------------------------
-- Bash safety hook (shell3.wrap_bash) — YOUR ONLY BASH GUARD.
-- ---------------------------------------------------------------------------
-- UNSAFE BY DEFAULT: bash and bash_bg run with no restrictions. This hook is the
-- ONLY place bash commands can be inspected, rewritten, or blocked. It receives
-- the command string and returns one of:
--   * a string        → run it under `bash -c` (rewrite the command text)
--   * a table         → an argv list exec'd directly — swaps the RUNNER, not
--                       just the text. The command is one argv element, so
--                       nothing re-parses it. e.g. sandbox in a container:
--                         return {"docker","exec","mycontainer","bash","-c",cmd}
--                       or swap the shell: return {"zsh","-c",cmd}
--   * nil/false[,why]  → block (optionally with a reason string)
-- A broken hook fails CLOSED (the command is blocked), never open.
--   -- example: block rm -rf, otherwise run normally
--   shell3.wrap_bash(function(cmd)
--     if cmd:match("rm%s+%-rf") then return nil, "refusing rm -rf" end
--     return cmd
--   end)
shell3.wrap_bash(function(cmd) return cmd end)

-- ---------------------------------------------------------------------------
-- Stub tools (optional) — redirect hallucinated tool calls to bash/edit_file.
-- ---------------------------------------------------------------------------
-- Models trained on other harnesses reflexively call read_file/grep/write_file.
-- Registering them as stubs returns a one-line redirect (a self-correcting nudge)
-- instead of erroring. Config-global: applies to every agent. Later keys override
-- earlier ones; a stub whose name collides with a real tool is ignored.
-- shell3.stub_tools({
