--     for _, p in ipairs(ASK)  do if p:match(t.command) then
--       if t.headless then return { block = true, reason = "needs approval; rerun interactively" } end
--       return { ask = "Run?\n" .. t.command, reason = "denied" }
--     end end
--   end
--   -- non-bash tools fire too — gate them by t.name + t.args, e.g.:
--   -- if t.name == "edit_file" and ENV:match(t.args) then return { block = true, reason = "no .env" } end
-- end)

-- Optional: rewrite a tool's OUTPUT before the model sees it (e.g. redact secrets).
-- Fires for EVERY tool; r.name is the real tool name ("bash", "edit_file", custom, ...).
-- Gate on r.name only if you mean to — for redaction you usually want all output.
