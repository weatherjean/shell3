-- ---------------------------------------------------------------------------
-- Stub tools — redirect hallucinated tool calls to bash/edit_file.
-- ---------------------------------------------------------------------------
-- shell3 has no file-read tools: reading and listing go through bash. Models
-- trained on other harnesses reflexively call read/read_file/grep/write_file;
-- each stub returns its one-line redirect (a self-correcting nudge) instead of
-- an error.
shell3.stub_tools({
  read        = "Use bash: cat <path>, or sed -n 'START,ENDp' <path> for a slice.",
  read_file   = "Use bash: cat <path>, or sed -n 'START,ENDp' <path> for a slice.",
  open_file   = "Use bash: cat <path>.",
  list_files  = "Use bash: ls <dir> or find <dir> -maxdepth 2.",
  list_dir    = "Use bash: ls <dir>.",
  grep        = "Use bash: rg <pattern>.",
  search      = "Use bash: rg <pattern>.",
  write_file  = "Use edit_file (empty old_string creates/overwrites).",
  create_file = "Use edit_file (empty old_string creates/overwrites).",
})

-- ---------------------------------------------------------------------------
-- Subagents (delegatable specialists the agent spawns via the task tool)
-- ---------------------------------------------------------------------------
local explorer = shell3.subagent({
  name        = "explorer",
  description = "Read-only investigation of the codebase — locate where/how something is implemented, summarize a subsystem, or gather context across many files. No edits.",
  model       = "{{.Name | luaesc}}",
  prompt = [[
You are a focused code explorer. Map structure with ls/find, read files with
cat/sed -n, and search contents with rg (all via bash; git log/show for
history). Report a concise, concrete answer with file:line references. You
cannot edit files. Decide and proceed; no human is available.
]],
  -- A read-only agent is a policy, not a tool set: gate bash in on_tool_call
  -- to inspection-only commands (rg/cat/sed -n/ls/git log ...).
  tools = { bash = true },
})

-- ---------------------------------------------------------------------------
-- The agent (exactly one shell3.agent; specialists are subagents)
-- ---------------------------------------------------------------------------
shell3.agent({
  name  = "code",
  model = "{{.Name | luaesc}}",
  -- Host-injected system-reminders (kept OUT of the prompt below). environment:
  -- config path, runs dir, model + this session's id. delegation: task-tool
  -- guidance + the subagents listed under tools.subagents below. Both default off.
  environment = true,
  delegation  = true,
  prompt = [[
You are an expert coding assistant inside shell3. Work autonomously as a senior pair-programmer: inspect, edit, test, and summarize clearly.

## Default workflow
- Understand the request, inspect relevant files, make minimal changes, format, validate, then summarize.
- For non-trivial work, agree on the approach in chat (the `brainstorming` skill helps) before editing.
- Bias for action on mild ambiguity; ask only for user-resolvable blockers: missing credentials, destructive operations, external account access, or unclear handling of existing user work.
- Read before writing (bash: cat, sed -n, rg). Prefer targeted edits. Show file paths clearly.
- Format and validate with the project's standard tools before considering work complete.
- Commit only when explicitly asked; push only when explicitly asked. Be concise.

## Discipline
- Act, don't narrate: when you say you'll run, check, or edit something, do it the same turn — never end a turn on stated intent you could have carried out.
- Finish the job: the deliverable is a working result backed by real tool output, not a description of one. Don't stop at a stub, a plan, or a single command.
- Evidence, never fabrication: a "done" / "passing" / "fixed" claim must rest on output you actually saw (you ran the test, read the file). If a step fails or is blocked, say so plainly and try another way — never present plausible-looking output you didn't produce.

## Tools
- `bash` is your only reader: cat / sed -n for files, ls / find for directories, rg for search.
- `edit_file`: prefer over `bash` heredocs; empty `old_string` creates or overwrites the whole file.
- `bash_bg`: long or parallel background work.
- `web_fetch`: fetch a URL as plain text + links. `brave_search`: web search.
- Delegation: spawn a listed subagent with the `task` tool ({subagent_type, prompt, description}) — it returns immediately and runs as an in-process background job; keep working, don't poll. Act on the completion notice; `task_status <id>` for detail, `task_list` / `task_cancel <id>` to manage. Good for parallelizable work you don't need to watch.
- Context is managed for you: shell3 auto-compacts long conversations. Never prune or compact manually.
]],
  tools = {
    bash              = true,
    bash_bg           = true,
    edit              = true,
    media             = true,
    subagents         = { explorer },
    custom            = { tools.web_fetch, tools.brave_search },
  },
  skills = { "lib/skills" },
})

-- ---------------------------------------------------------------------------
-- Telegram host  (run: shell3 telegram)
-- ---------------------------------------------------------------------------
-- chat_id is the single chat the bot answers. The dashboard Mini App needs a
-- public https URL; shell3 wires the chat's menu button to it automatically:
--   tunnel: a command spawned at start ({addr} = dashboard addr) whose printed
--           https URL is picked up. cloudflared must be installed, or the
--           dashboard stays local-only (see ~/.shell3/tunnel.log).
--   url:    a fixed https address you run yourself; overrides tunnel.
shell3.telegram({
  token   = shell3.env.secret("TELEGRAM_BOT_TOKEN"),  -- TELEGRAM_BOT_TOKEN in .env
  chat_id = "{{.ChatID | luaesc}}",
  dashboard = {
    enabled = true,
    addr    = "127.0.0.1:8765",
    tunnel  = "cloudflared tunnel --url http://{addr}",
  },
})

-- Standalone web front-end  (run: shell3 web) — Telegram-free fallback:
-- the same dashboard plus a simple chat, gated by a shared secret instead of
-- Telegram. `shell3 boot` generates SHELL3_WEB_SECRET in .env, and `shell3
-- web` prints the ready-to-open ?key= URL at startup (rotate by editing .env).
-- Run one front-end at a time (telegram OR web); both own the same history.
shell3.web({
  addr   = "127.0.0.1:8787",
  secret = shell3.env.secret("SHELL3_WEB_SECRET"),
  -- tunnel = "cloudflared tunnel --url http://{addr}",  -- optional public URL
})

