-- shell3.lua — base config written by `shell3 boot`. Edit freely.
-- Secrets live in .env beside this file (never commit it).
-- Add tools, skills, or agents by editing — see the cookbook in
-- the shell3 repo under docs/cookbook/.

local tools  = require("lib.tools")            -- { web_fetch, brave_search }

-- Skills: every *.md in the dirs an agent lists under skills={} is one skill —
-- markdown with a frontmatter `description:`. Drop a file into lib/skills/ and
-- /reload; `shell3 health` flags files the loader had to skip.

-- ---------------------------------------------------------------------------
-- Model
-- ---------------------------------------------------------------------------
shell3.model("{{.Name | luaesc}}", {
  base_url       = "{{.BaseURL | luaesc}}",
  api_key        = shell3.env.secret("{{.EnvKey}}"),  -- {{.EnvKey}} in .env
  model          = "{{.Model | luaesc}}",
  -- context_window: your model's token budget. Set it to the real value for
  -- this model — the wrong number throws off context-usage reminders and compaction.
  context_window = {{.ContextWindow}},
  -- compact_at: absolute prompt-token threshold for host-enforced auto-compaction.
  -- When a turn's prompt reaches it, shell3 summarizes the head and keeps a verbatim
  -- recent tail — no model-driven prune/compact tools. 0/unset = off.
  compact_at     = {{.CompactAt}},
  -- keep_recent: verbatim tail (in prompt tokens) preserved across a compaction.
  --   Defaults to round(compact_at * 0.33); clamped to round(compact_at * 0.5) if >= compact_at.
  --   Uncomment to override with an absolute token count, e.g.:
  -- keep_recent  = 30000,
  -- prune_at: lower threshold; cheaply stubs old tool outputs with no LLM call.
  --   Defaults to round(compact_at * 0.6); set to 0 to disable; ignored if >= compact_at.
  --   Uncomment to override with an absolute token count, e.g.:
  -- prune_at     = 60000,
  -- reasoning   = "medium",   -- uncomment if your model supports reasoning effort
  -- extra: provider-specific fields injected verbatim as top-level JSON on each
  -- request. Leave empty unless your provider needs a non-standard knob — strict
  -- endpoints reject unknown fields. e.g. MiniMax routes thinking to reasoning_content:
  -- extra       = { reasoning_split = true },
  -- run_proxy: shell command auto-started (detached, fire-and-forget) the first
  -- time an agent uses this model. Use it to bring up a local proxy in front of
  -- base_url — e.g. a Codex subscription fronted by `npx ...`.
  -- Output goes to ~/.shell3/proxy-{{.Name}}.log.
{{if .Proxy}}  run_proxy      = "{{.Proxy | luaesc}}",
{{else}}  -- run_proxy   = "npx @some/codex-proxy --port 8787",
{{end}}})

-- ---------------------------------------------------------------------------
-- Command gate — shell3.on_tool_call (YOUR ONLY POLICY GATE)
-- ---------------------------------------------------------------------------
-- UNSAFE BY DEFAULT: tools run with no restrictions. on_tool_call is the one place
-- a model-issued action can be inspected, rewritten, routed, or blocked. It fires
-- before EVERY tool with the real t.name (bash, bash_bg, edit_file, read_media,
-- custom). t.command is the bash text for the two bash tools and NIL otherwise
-- — so guard on t.name before matching t.command.
-- Handlers are chainable (declaration order) and receive t = { name, command, args, headless }.
-- Return one of:
--   * nil                         → pass to the next handler / run
--   * { command = "..." }         → rewrite the bash text, continue (bash tools only)
--   * { argv = {...} }            → exec this argv directly (runner swap; bash/bash_bg
-- only)
--   * { block = true, reason="" } → block (reason shown to the model)
--   * { ask = "prompt", reason="" } → ask a human (Telegram Allow/Deny buttons);
--                                   allowed → run, declined/headless → block(reason)
--   t.headless is true when no human is attached (subagents, cron jobs) — an
--   ask would auto-deny there, so branch on it to block with a clearer reason
--   (or allow a safe subset) instead of asking.
-- Write denylists with shell3.regex (Go RE2; compiled at load). Use (?s) so .*
-- spans multi-line commands. A handler that errors FAILS CLOSED (blocks).
-- Example (uncomment to enable a guard):
