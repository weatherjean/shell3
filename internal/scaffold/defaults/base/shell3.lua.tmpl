-- local ASK  = { re([[(?s)rm\s+-rf]]), re([[(?s)\bgit\s+push]]), re([[(?s)curl\b.*\|\s*(ba)?sh]]) }
-- local ENV  = re([[\.env]]) -- hoisted like the lists above: compiled once at load
