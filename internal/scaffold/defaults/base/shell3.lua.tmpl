-- shell3.lua — base config written by `shell3 boot`. Edit freely; recipes
-- live in the shell3 repo under docs/cookbook/.
-- Secrets live in .env beside this file (never commit it).

local tools  = require("lib.tools")            -- { web_fetch, brave_search }

-- Skills: every *.md in the dirs an agent lists under skills={} is one skill —
-- markdown with a frontmatter `description:`. Drop a file into lib/skills/ and
-- /reload; `shell3 health` flags files the loader had to skip.

-- ---------------------------------------------------------------------------
-- Model
-- ---------------------------------------------------------------------------
shell3.model("{{.Name | luaesc}}", {
  base_url       = "{{.BaseURL | luaesc}}",
  api_key        = shell3.env.secret("{{.EnvKey}}"),  -- {{.EnvKey}} in .env
  model          = "{{.Model | luaesc}}",
  -- context_window: your model's real token budget (wrong values skew
  -- context-usage reminders and compaction).
  context_window = {{.ContextWindow}},
  -- compact_at: prompt-token threshold for host-enforced auto-compaction —
  -- shell3 summarizes the head and keeps a verbatim recent tail. 0/unset = off.
  compact_at     = {{.CompactAt}},
  -- keep_recent: verbatim tail kept across a compaction (default ~compact_at*0.33).
  -- keep_recent  = 30000,
  -- prune_at: lower threshold; cheaply stubs old tool outputs, no LLM call
  -- (default ~compact_at*0.6; 0 disables).
  -- prune_at     = 60000,
  -- reasoning   = "medium",   -- uncomment if your model supports reasoning effort
  -- extra: provider-specific fields injected verbatim as top-level JSON — only
  -- if your provider needs a knob, e.g. MiniMax:
  -- extra       = { reasoning_split = true },
  -- run_proxy: shell command auto-started the first time an agent uses this
  -- model — a local proxy in front of base_url. Log: ~/.shell3/proxy-{{.Name}}.log.
{{if .Proxy}}  run_proxy      = "{{.Proxy | luaesc}}",
{{else}}  -- run_proxy   = "npx @some/codex-proxy --port 8787",
{{end}}})

