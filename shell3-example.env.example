# shell3-example.env.example
# Copy this file to .env (next to your shell3.lua) and fill in your keys.
# Never commit the .env file — it contains secrets.

# API key for the OpenAI-compatible endpoint used by the "main" model.
OPENCODE_KEY=

# Brave Search API key for the brave_search tool.
# Get one at: https://brave.com/search/api/
BRAVE_API_KEY=
